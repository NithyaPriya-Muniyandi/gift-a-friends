---
import ahf from './../assets/Alumni/ahf.webp';
import apin from './../assets/Alumni/apin.webp';
import baylor from './../assets/Alumni/baylor.webp';
import delta from './../assets/Alumni/delta.webp';
import fmc from './../assets/Alumni/fmc.webp';
import rusangu from './../assets/Alumni/rusangu.webp';
import sultan from './../assets/Alumni/sultan.webp';
import tezpur from './../assets/Alumni/tezpur.webp';
import unicef from './../assets/Alumni/unicef.webp';
import who from './../assets/Alumni/who.webp';
import { Image } from 'astro:assets';
// Import your images
const images = [ahf, apin, baylor, delta, fmc, rusangu, sultan, tezpur, unicef, who];
---

<section class="pb-8 pt-3 md:pb-16 bg-gradient-to-b from-transparent to-yellow-100/50">
  <div class="container mx-auto w-full lg:w-9/12">
    <div class="text-center">
      <h2 class="text-2xl md:text-3xl font-bold text-[#121212] mb-6">Our Alumni Work At</h2>
    </div>

    <div class="relative overflow-hidden">
      <!-- Swiper container -->
      <div class="swiper-container !overflow-hidden">
        <div class="swiper-wrapper">
          {images.map((image, index) => (
            <div class="swiper-slide">
              <div class="alumni-item">
                <Image 
                  src={image} 
                  alt={`Alumni company ${index + 1}`}
                  class="w-full h-auto object-contain mx-auto"
                  loading="lazy"
                />
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <p class="text-xs text-gray-500 text-center mt-6 px-4 md:px-20">
      Disclaimer: The company logos displayed in the alumni section of this page are trademarks of their respective owners. 
      The presence of these logos does not imply any endorsement or direct affiliation with Texila American University. 
      They are provided solely to indicate the companies where our alumni are currently employed.
    </p>
  </div>
</section>

<script>
  import Swiper from 'swiper';
  import { Autoplay } from 'swiper/modules';
  
 new Swiper('.swiper-container', {
  modules: [Autoplay],
  slidesPerView: 2,
  spaceBetween: 20,
  loop: true,
  autoplay: {
    delay: 3000,
    disableOnInteraction: false,
  },
  breakpoints: {
    640: {
      slidesPerView: 3,
    },
    768: {
      slidesPerView: 4,
    },
    1024: {
      slidesPerView: 5,
    },
  },
});
</script>

<style>
.swiper-container {
  overflow: hidden;
  width: 100%;
  position: relative;
  padding: 1rem 0;
}

.swiper-wrapper {
  display: flex;
  transition-timing-function: ease-in-out;
  will-change: transform;
}

.swiper-slide {
  flex-shrink: 0;
  width: auto;
  display: flex;
  align-items: center;
  justify-content: center;
}

.alumni-item img {
  max-height: 100px;
  object-fit: contain;
}

@media (max-width: 640px) {
  .alumni-item img {
    height: 90px;
  }
}

</style>