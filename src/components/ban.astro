  <script is:client>
    function updateCourses() {
      const category = document.getElementById('category').value;
      const courseSelect = document.getElementById('course');

      const courseOptions = {
        "Guyana DBLP": [
          "Doctor of Public Health Administration",
          "Doctor of Business Administration",
          "Master of Public Health",
          "PhD in Management",
          "PhD in Nursing",
          "PhD in Public Health"
        ],
        "Zambia DBLP": [
          "Bachelor of Public Health",
          "Master of Public Health",
          "PhD in Public Health",
          "Master of Business Administration",
          "Master of Science in Project Management",
          "PhD in Management"
        ],
        "Zambia Medicine": [
          "Bachelor of Medicine and Bachelor of Surgery",
          "Health Profession and Foundation Programme"
        ],
        "Guyana Medicine": [
          "Doctor of Medicine"
        ],
        "PG Medicine": [
          "MRCP Clinical Premier Training",
          "MRCS Clinical Premier Training",
          "FRCR Clinical Premier Training",
          "MRCOG Clinical Premier Training",
          "MRCPCH Clinical Premier Training",
          "Fellowship in Clinical Cardiology with Critical Care"
        ]
      };

      // Reset course dropdown
      courseSelect.innerHTML = '<option value="" selected disabled>Select Program Course</option>';

      if (category && courseOptions[category]) {
        courseOptions[category].forEach(course => {
          const option = document.createElement('option');
          option.value = course;
          option.textContent = course;
          courseSelect.appendChild(option);
        });
      }
    }
  </script>
  <script>
    const form = document.getElementById("referralForm");
    const emailInput = document.getElementById("referral_email");
    const phoneInput = document.getElementById("referral_mobile");
    const counterDisplay = document.getElementById("submissionCounter");
    const storageKey = "userReferralSubmissions";

    function getSubmissionList() {
      const stored = localStorage.getItem(storageKey);
      return stored ? JSON.parse(stored) : [];
    }

    function setSubmissionList(list) {
      localStorage.setItem(storageKey, JSON.stringify(list));
    }

    function updateCounterUI(count) {
      if (!counterDisplay) return;
      counterDisplay.classList.remove("hidden");
      counterDisplay.textContent = `${count}`;
    }

    window.addEventListener("DOMContentLoaded", () => {
      const submissions = getSubmissionList();
      updateCounterUI(submissions.length);
    });

    // ✅ No querySelector here; just use the form directly
    form.addEventListener("submit", function (e) {
      const email = emailInput.value.trim().toLowerCase();
      const phone = phoneInput.value.trim();

      let submissions = getSubmissionList();

      const isEmailUsed = submissions.some(entry => entry.email === email);
      const isPhoneUsed = submissions.some(entry => entry.phone === phone);

      if (isEmailUsed || isPhoneUsed) {
        e.preventDefault();
        alert("This email or phone number has already been used. Please use completely new details.");
        return;
      }

      submissions.push({ email, phone });
      setSubmissionList(submissions);
      updateCounterUI(submissions.length);

      if (submissions.length === 5) {
        alert("✅ You've completed the minimum 5 submissions. You may continue to refer more!");
      }
    });
  </script>

