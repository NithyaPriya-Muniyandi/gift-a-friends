    ---
    import { Image } from "astro:assets";
    import arrow from '../assets/buttonarrow.webp';
    import logo from '../assets/logo.webp';

    const currentUrl = Astro.url.href;
    const parsedUrl = new URL(currentUrl);
    const params = parsedUrl.searchParams;
    const campaignNameCustom = params.get('campaign_name_custom') || '';
    const netcore = params.get('netcore_activity_source') || '';
    const leadSource = params.get('lead_source') || '';
    const utmTerm = params.get('utm_term') || '';
    ---

    <section
      class="thank-you-banner bg-cover bg-center flex items-center justify-center text-center px-6 py-30 md:py-20"
    >
      <div class="max-w-8xl mx-auto md:px-4">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <!-- Logo -->
          <div>
            <img src={logo.src} alt="Logo" class="w-[160px] mt-8 md:-mt-8" />
          </div>

          <!-- Content -->
          <div class="text-left md:items-center md:justify-center flex flex-col">
            <h1 class="text-3xl w-[60%] md:w-full md:text-6xl font-bold mb-6 uppercase text-shadow-lg gap-3">
              <span class="text-outline-black">Gift a Friend &</span>
              <span class="text-outline-black-yellow"> Get Rewarded!</span>
            </h1>
            <h2 class="text-2xl w-[80%] md:w-full md:text-4xl text-blue-fill-yellow-stroke font-extrabold text-shadow-lg mb-6 uppercase">
              Refer 5 Friends & Get a CPD Course FREE
            </h2>
            <p class="bg-white rounded-lg md:p-4 text-gray-800 max-w-xl">
              We believe good education should be shared and rewarded! With our <strong>“Gift a Friend” referral campaign,</strong> you can help your friends grow while earning a FREE CPD course for yourself.
            </p>
          </div>

          <!-- Form -->
          <div>
            <div class="bg-gradient-to-b from-yellow-100 to-blue-100 p-6 max-w-md border border-blue-500 shadow-[6px_6px_0px_#333333]">
              <form id="referralForm" action="https://apply.tauedu.org/lp/send_data_gift.php" method="post" class="space-y-4">
                <div id="initialDetails" class="space-y-4">
                  <h3 class="text-lg md:text-2xl font-semibold mb-4 text-left text-[#2F2E67]">FILL YOUR INFORMATION</h3>

                  <div class="flex flex-col md:flex-row gap-4">
                    <input type="text" id="name" name="name" placeholder="Your Name*" required
                      class="w-full border border-gray-400 p-2 focus:outline-none focus:ring-2 focus:ring-blue-500" />

                    <input type="email" id="email" name="email" placeholder="Your Email*" required
                      class="w-full border border-gray-400 p-2 focus:outline-none focus:ring-2 focus:ring-blue-500" />
                  </div>

                  <div class="flex flex-col md:flex-row gap-4">
                    <select id="country_code" name="country_code" required
                      class="w-full border border-gray-400 p-2 focus:outline-none focus:ring-2 focus:ring-blue-500">
