---
import IconTop from './../assets/stu.webp';
import Alumni from './../assets/award.webp';
import Book from './../assets/book.webp';
---
<section class="bg-[#114869] text-white relative overflow-hidden py-8 md:py-0">
    <div class="flex flex-col md:flex-row">
      
      <!-- Left Content Section -->
      <div class="w-full md:w-1/12"></div>
      <div class="w-full md:w-5/12 md:px-4 pb-8 md:py-12">
        <div class="max-w-[90%] mx-auto">
          <h2 class="text-2xl md:text-3xl font-semibold mb-4 leading-8 md:leading-[2] text-center md:text-left">
            Benefits of Studying a Public Health
          </h2>
  
          <ul class="list-none space-y-4">
            <li class="pl-10 bg-[url('./../assets/yellowArrow.webp')] bg-no-repeat leading-relaxed md:leading-loose">
              Designed specifically for working professionals.
            </li>
            <li class="pl-10 bg-[url('./../assets/yellowArrow.webp')] bg-no-repeat leading-relaxed md:leading-loose">
              Program delivered by distinguished faculty.
            </li>
            <li class="pl-10 bg-[url('./../assets/yellowArrow.webp')] bg-no-repeat leading-relaxed md:leading-loose">
              Personalized attention and guidance throughout the program.
            </li>
            <li class="pl-10 bg-[url('./../assets/yellowArrow.webp')] bg-no-repeat leading-relaxed  md:leading-loose">
              University appointed co-guides.
            </li>
            <li class="pl-10 bg-[url('./../assets/yellowArrow.webp')] bg-no-repeat leading-relaxed md:leading-loose">
              Online access to comprehensive e-Library.
            </li>
            <li class="pl-10 bg-[url('./../assets/yellowArrow.webp')] bg-no-repeat leading-relaxed md:leading-loose">
              Contribute to the enrichment and advancement of knowledge.
            </li>
          </ul>
        </div>
      </div>
  
<div
class="w-full md:w-6/12 md:min-h-[600px] relative flex justify-center md:justify-start items-center
        bg-none md:bg-[url('./../assets/benefit.webp')] md:bg-no-repeat md:bg-cover md:bg-right"
>
<!-- Vertical Stats Overlay (Always Visible) -->
<div class="flex flex-row sm:flex-col md:absolute md:top-1/2 mt-5 md:mt-0 md:left-0 md:transform md:-translate-y-1/2 md:-translate-x-1/2 items-center justify-center gap-4">
  <div class="bg-[#FFE44D] md:rounded-full h-[110px] w-[110px] md:h-[150px] md:w-[150px] text-center p-5 flex flex-col justify-center items-center shadow-lg">
    <img src={IconTop.src} alt="Students" class="w-10 mb-2" />
    <p class="text-[#1D1D1D] text-lg leading-tight font-serif">
      <strong class="text-2xl">18K+</strong><br />
      Students
    </p>
  </div>

  <div class="bg-[#FFE44D] md:rounded-full h-[110px] w-[110px] md:h-[150px] md:w-[150px] text-center p-5 flex flex-col justify-center items-center shadow-lg">
    <img src={Alumni.src} alt="Alumni" class="w-10 mb-2" />
    <p class="text-[#1D1D1D] text-lg leading-tight font-serif">
      <strong class="text-2xl">4K+</strong><br />
      Alumni
    </p>
  </div>

  <div class="bg-[#FFE44D] md:rounded-full h-[110px] w-[110px] md:h-[150px] md:w-[150px] text-center p-5 flex flex-col justify-center items-center shadow-lg">
    <img src={Book.src} alt="Programs" class="w-10 mb-2" />
    <p class="text-[#1D1D1D] text-lg leading-tight font-serif">
      <strong class="text-2xl">25+</strong><br />
      Programs
    </p>
  </div>
</div>
</div>
    </div>
  </section>
  