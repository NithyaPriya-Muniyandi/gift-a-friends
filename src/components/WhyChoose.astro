---
import student from './../assets/student-why.webp';
import idea from './../assets/blub.webp';
import book from './../assets/book.webp';
import quality from './../assets/globe.webp';
import success from './../assets/win.webp';
import ButtonArrow from './../assets/arrow.webp';
import chat from './../assets/chat.webp';
import client from './../assets/client.webp';
---

<section class="bg-white md:py-16">
  <div class="container mx-auto px-4">
    <div class="flex flex-col lg:flex-row lg:items-start gap-8">
      <!-- Left Column -->
      <div class="w-full lg:w-1/12 text-center"></div>
      <div class="w-full lg:w-3/12 text-center">
        <h2 class="text-center text-2xl md:text-3xl font-bold mb-4 text-[#121212] mb-4">Why Choose Us</h2>
        <img src={student.src} alt="Student" class="mx-auto mb-4 hidden md:block" />
        <div class="text-center mt-8">
            <a href="#apply" class="inline-flex items-center justify-center px-6 py-3 bg-[#114869] text-white rounded-md text-sm font-medium transition">
              Enroll today for early bird offers!
              <img src={ButtonArrow.src} alt="Arrow" class="ml-3 w-4 h-4" />
            </a>
          </div>
      </div>

      <!-- Right Column -->
      <div class="w-full lg:w-7/12">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-6">
          <!-- Box 1 -->
          <div class="why-box bg-white border border-gray-300 p-6 text-center text-gray-800 rounded-md shadow-sm">
            <img src={idea.src} alt="Idea Icon" class="mx-auto mb-3" />
            <h4 class="font-bold mb-3">Innovation</h4>
            <p>Texila American University invites you to a world where learning is an adventure and excellence is the destination.</p>
          </div>

          <!-- Box 2 -->
          <div class="why-box bg-white border border-gray-300 p-6 text-center text-gray-800 rounded-md shadow-sm">
            <img src={quality.src} alt="Quality Icon" class="mx-auto mb-3" />
            <h4 class="font-bold mb-3">Global Community, Local Support</h4>
            <p>Join a vibrant international family while receiving personalized attention that fuels your unique academic path.</p>
          </div>

          <!-- Box 3 -->
          <div class="why-box bg-white border border-gray-300 p-6 text-center text-gray-800 rounded-md shadow-sm">
            <img src={success.src} alt="Success Icon" class="mx-auto mb-3" />
            <h4 class="font-bold mb-3">Your Success, Our Priority</h4>
            <p>Experience a campus designed to nurture your growth with state-of-the-art facilities and a commitment to your journey.</p>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="why-box bg-white border border-gray-300 p-6 text-center text-gray-800 rounded-md shadow-sm">
            <img src={book.src} alt="Book Icon" class="mx-auto mb-3" />
            <h4 class="font-bold mb-3">Programs at the Frontier</h4>
            <p>Dive into programs that aren’t just courses but gateways to cutting-edge knowledge and skills.</p>
          </div>

        <div class="why-box bg-white border border-gray-300 p-6 text-center text-gray-800 rounded-md shadow-sm">
            <img src={chat.src} alt="Book Icon" class="mx-auto mb-3" />
            <h4 class="font-bold mb-3">Inspiring Mentors</h4>
            <p>Learn from top-notch professors dedicated to teaching and guiding you towards success.</p>
          </div>
       

        <div class="why-box bg-white border border-gray-300 p-6 text-center text-gray-800 rounded-md shadow-sm">
            <img src={client.src} alt="Book Icon" class="mx-auto mb-3" />
            <h4 class="font-bold mb-3">Leadership in the Making</h4>
            <p>Texila American University is not just an institution but a launchpad for tomorrow’s leaders.</p>
          </div>
        </div>

       

        <!-- Button -->
        
      </div>
      <div class="w-full lg:w-1/12 text-center"></div>
    </div>
    </div>
  </div>
</section>

<style>
  @media (max-width: 1400px) {
    .why-box {
      height: auto !important;
    }
  }
</style>
