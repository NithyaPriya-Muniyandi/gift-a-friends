---
import { Image } from 'astro:assets';
import icon1 from '../assets/germany.webp';
import icon2 from '../assets/graduation.webp';
import icon3 from '../assets/onlinebook.webp';
import abouticon from '../assets/buttonbtn.webp';
import refer from '../assets/referarrow.webp';
---
<section class="bg-[#F8F8F8]">
  <div class="max-w-7xl mx-auto px-4">
    <div class="grid grid-cols-12">
      <!-- Left Column: 5/12 -->
      <div class="col-span-12 md:col-span-5 bg-[#D7E4F6] py-10 md:py-20 px-6 md:px-10">
        <h2 class="text-xl md:text-3xl font-extrabold font-bold text-[#2F2E67] uppercase mb-6">About TAU’s Global Impact</h2>

       <ul class="space-y-6 text-[#1B1B1B] font-medium">
  <li class="flex items-center gap-4 bg-white shadow-md rounded-lg p-4">
    <Image src={icon1} alt="Icon 1" />
    <span>Students from 70+ countries</span>
  </li>
  <li class="flex items-center gap-4 bg-white shadow-md rounded-lg p-4">
    <Image src={icon2} alt="Icon 2" />
    <span>Alumni placed in top organizations worldwide</span>
  </li>
  <li class="flex items-center gap-4 bg-white shadow-md rounded-lg p-4">
    <Image src={icon3} alt="Icon 3" />
    <span>A trusted name in online education in Africa, Asia & the Caribbean</span>
  </li>
</ul>


        <p class=" mt-8 text-[#1B1B1B]">
          At TAU, we rise by lifting others. Gift your friends the power of education and unlock your own learning journey.
        </p>
      </div>

      <!-- Right Column: 7/12 -->
      <div class="col-span-12 md:col-span-7 py-10 md:py-20 px-6 md:px-10">
<div class="flex flex-col md:flex-row items-start gap-4 mb-6">
  <!-- Heading -->
  <h2 class="text-xl md:text-2xl font-extrabold text-[#2F2E67] uppercase leading-tight md:w-2/6 leading-relaxed">
    Empowering Futures Through World-Class Education
  </h2>

  <!-- Paragraph -->
  <p class="text-gray-700 md:w-4/6">
    Texila American University (TAU) is a leading, internationally recognized university offering quality higher education to students across the globe. With over a decade of academic excellence, TAU is committed to delivering career-relevant programs through flexible online learning formats that fit the lifestyle of working professionals and aspiring students alike.
  </p>
</div>

        <h3 class="font-bold mb-2 text-[#2F2E67] text-md md:text-xl">Our university is known for its:</h3>
       <div class="flex flex-col md:flex-row flex-wrap gap-2 mb-3">
  <div class="flex-[1_1_calc(50%-0.25rem)] p-3 mb-3 border border-[#2F2E67] rounded-lg text-sm bg-white flex flex-row items-center gap-3 shadow-md">
    <Image src={abouticon} alt="img" />
    <p>Global Accreditation and Recognition</p>
  </div>
  <div class="flex-[1_1_calc(50%-0.25rem)] p-3 mb-3 border border-[#2F2E67] rounded-lg text-sm bg-white flex flex-row items-center gap-3 shadow-md">
    <Image src={abouticon} alt="img" />
    <p>Industry-Relevant Curriculum</p>
  </div>
  <div class="flex-[1_1_calc(50%-0.25rem)] p-3 mb-3 border border-[#2F2E67] rounded-lg text-sm bg-white flex flex-row items-center gap-3 shadow-md">
    <Image src={abouticon} alt="img" />
    <p>Experienced International Faculty</p>
  </div>
  <div class="flex-[1_1_calc(50%-0.25rem)] p-3 mb-3 border border-[#2F2E67] rounded-lg text-sm bg-white flex flex-row items-center gap-3 shadow-md">
    <Image src={abouticon} alt="img" />
    <p>Student-Centered Learning Models</p>
  </div>
</div>


        <p class="text-gray-700 mb-6">
          Whether you're pursuing a Bachelor's, Master's, PhD, or CPD (Continuing Professional Development) course...
        </p>

        <a href="#referralForm" class="inline-flex items-center bg-[#2F2E67] text-white px-5 border border-yellow-500 py-2 rounded-md shadow-md hover:bg-[#1e1d5c]">
          Refer Now
          <Image src={refer} alt="Arrow" class="ml-2" />
           </a>
      </div>
    </div>
  </div>
</section>

