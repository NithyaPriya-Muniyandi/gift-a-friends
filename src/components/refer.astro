---
import {Image} from 'astro:assets';
import but from '../assets/button.webp';
import book from '../assets/book.webp';
import learning from '../assets/learning.webp';
import medal from '../assets/medal.webp';
---
<section class="grid grid-cols-1 md:grid-cols-2">
  <!-- Left: Who Can You Refer -->
   <div class="bg-[#2F2E67] justify-end items-center flex flex-col md:flex-row">
  <div class="max-w-3xl text-white p-8 md:p-12">
    <h2 class="text-xl md:text-3xl font-extrabold uppercase mb-6">Who can you refer?</h2>
    <ul class="space-y-5 leading-relaxed">
      <li class="flex items-start gap-2">
       <Image src={but} alt="arrow" />
        <span>Friends, classmates, colleagues, or family</span>
      </li>
      <li class="flex items-start gap-2">
        <Image src={but} alt="arrow" />
        <span>
          Anyone aspiring to enroll in online Bachelor's, Master's, or Doctoral programs
        </span>
      </li>
      <li class="flex items-start gap-2">
        <Image src={but} alt="arrow" />
        <span>People looking for career advancement through quality education</span>
      </li>
    </ul>
  </div>
</div>
  <!-- Right: Start Sharing, Start Earning -->
   <div class="bg-[#C9D7F8] justify-start items-center flex flex-col md:flex-row">
  <div class="max-w-3xl  p-8 md:p-12">
    <h2 class="text-xl md:text-3xl font-extrabold text-[#2F2E67] uppercase mb-2">Start Sharing, Start Earning</h2>
    <p class="text-[#1B1B1B] mb-6">The more you refer, the more you unlock!</p>

    <div class="flex flex-col md:flex-row gap-4">
  <!-- Card 1 -->
  <div class="bg-white rounded-xl shadow-md flex-1 flex flex-col justify-between text-center px-4 py-6">
    <p class="text-sm font-medium text-[#2F2E67] mb-4">
      Refer 5 friends = <br /> 1 FREE CPD course
    </p>
    <Image src={book} alt="CPD Icon" class="w-10 h-10 mx-auto" />
  </div>

  <!-- Card 2 -->
  <div class="bg-white rounded-xl shadow-md flex-1 flex flex-col justify-between text-center px-4 py-6">
    <p class="text-sm font-medium text-[#2F2E67] mb-4">
      Refer 10 friends = <br /> 2 FREE CPD courses
    </p>
    <Image src={learning} alt="CPD Icon" class="w-10 h-10 mx-auto" />
  </div>

  <!-- Card 3 -->
  <div class="bg-white rounded-xl shadow-md flex-1 flex flex-col justify-between text-center px-4 py-6">
    <p class="text-sm font-medium text-[#2F2E67] mb-4">
      No limits to your <br /> rewards
    </p>
    <Image src={medal} alt="CPD Icon" class="w-10 h-10 mx-auto" />
  </div>
</div>

  </div></div>
</section>
