---
import { Image } from 'astro:assets';
import smileImage from './../assets/smile.webp';
import arrowLeft from './../assets/arrow-left.png';
import arrowRight from './../assets/arrow-right.png';
---

<div class="testimonial-carousel relative">
    <div class="carousel-inner">
      <h2 class="text-2xl md:text-3xl font-bold text-center mb-6 text-[#121212]">Student Testimonials</h2>
      <div class="testimonial-item active">
        <div class="bg-white/50 rounded-lg shadow-lg overflow-hidden">
          <div class="p-4 text-center">
            <div class="mb-6 flex justify-center">
                <Image src={smileImage} alt="Student"/>
              </div>
            <p class="text-gray-700 mb-4 leading-relaxed">
                My time at TAU was enriching, with supportive mentors, readily available academic resources, and flexible learning options. I chose a Public Health program aligned with my passion, empowering me for my role as a Community Health Officer. TAU’s modern approach, student-centered environment, and flexible fees recommend it.
            </p>
            <h5 class="text-lg font-medium text-gray-900">Ms. Mable Mukuma Kalumba</h5>
          </div>
        </div>
      </div>
  
      <!-- Testimonial 2 -->
      <div class="testimonial-item hidden">
        <div class="bg-white/50 rounded-lg shadow-lg overflow-hidden">
          <div class="p-4 text-center">
            <div class="mb-6 flex justify-center">
                <Image src={smileImage} alt="Student"/>
              </div>
            <p class="text-gray-700 mb-4 leading-relaxed">
                I joined Texila’s MPH in May 2020; I am empowered and excelling in my NGO managerial role. Unleash potential and reshape your future with us. The flexible Saturday Zoom lectures seamlessly blended with my work schedule, and the student-friendly fee plan made my academic journey a success within two years. Grateful for the opportunity.
            </p>
            <h5 class="text-lg font-medium text-gray-900">Dr. Nelson Agweh Musaga</h5>
          </div>
        </div>
      </div>
    </div>
  
    <!-- Navigation arrows -->
    <button class="carousel-control-prev absolute top-1/2 left-0 transform -translate-y-1/2 lg:-left-14 focus:outline-none" aria-label="Previous testimonial">
        <span class="carousel-control-prev-icon w-12 h-12 flex items-center justify-center">
          <Image src={arrowLeft} alt="Previous" class="w-10 h-10 object-contain" />
        </span>
      </button>
      
      <button class="carousel-control-next absolute top-1/2 right-0 transform -translate-y-1/2 lg:-right-14 focus:outline-none" aria-label="Next testimonial">
        <span class="carousel-control-next-icon w-12 h-12 flex items-center justify-center">
          <Image src={arrowRight} alt="Next" class="w-10 h-10 object-contain" />
        </span>
      </button>
  </div>
  
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const items = document.querySelectorAll('.testimonial-item');
      const prevBtn = document.querySelector('.carousel-control-prev');
      const nextBtn = document.querySelector('.carousel-control-next');
      let currentIndex = 0;
      const intervalTime = 5000;
      let intervalId;
  
      function showSlide(index) {
        // Hide all items
        items.forEach(item => {
          item.classList.add('hidden');
          item.classList.remove('active', 'animate-fade-in');
        });
  
        // Show current item
        items[index].classList.remove('hidden');
        items[index].classList.add('active', 'animate-fade-in');
      }
  
      function nextSlide() {
        currentIndex = (currentIndex + 1) % items.length;
        showSlide(currentIndex);
      }
  
      function prevSlide() {
        currentIndex = (currentIndex - 1 + items.length) % items.length;
        showSlide(currentIndex);
      }
  
      // Set up automatic rotation
      function startInterval() {
        intervalId = setInterval(nextSlide, intervalTime);
      }
  
      function resetInterval() {
        clearInterval(intervalId);
        startInterval();
      }
  
      // Event listeners
      if (prevBtn) {
        prevBtn.addEventListener('click', () => {
          prevSlide();
          resetInterval();
        });
      }
  
      if (nextBtn) {
        nextBtn.addEventListener('click', () => {
          nextSlide();
          resetInterval();
        });
      }
  
      // Initialize carousel
      showSlide(currentIndex);
      startInterval();
    });
  </script>
  
  <style>
    .testimonial-item {
      transition: opacity 0.5s ease;
    }
    
    @media (max-width: 640px) {
      .carousel-control-prev,
      .carousel-control-next {
        display: none;
      }
    }
  </style>