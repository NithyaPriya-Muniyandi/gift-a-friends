---
// Import icons from assets
import mailIcon from '../assets/email.webp';
import whatsappIcon from '../assets/whatsapp.webp';
---

<section class="py-10 md:py-20 bg-[#393848] text-white">
  <div class="max-w-6xl mx-auto px-4">
    <h2 class="text-xl md:text-3xl font-extrabold uppercase text-center">Need Assistance?</h2>
    <p class="text-yellow-400 text-sm md:text-xl mt-1 mb-6 text-center">Our team is here to guide you.</p>

    <div class="flex justify-center items-center mb-6">
 <div class="flex flex-col md:flex-row justify-start md:justify-center items-center gap-6 text-sm font-medium mb-6">
    <div class="flex items-center gap-2 w-full md:w-auto">
      <img src={mailIcon.src} alt="Mail Icon" />
      <span>priya.prabu@tauedu.org</span>
    </div>
    <div class="flex items-center gap-2 w-full md:w-auto">
      <img src={whatsappIcon.src} alt="WhatsApp Icon" />
      <span class="text-yellow-300">+91 8056770538</span>
    </div>
    </div>
  </div>
    <hr class="border-gray-400 mb-4" />
    <p class="text-sm text-gray-300 text-center">
  &copy; <span id="year"></span>, Texila American University. All Rights Reserved
</p>

  </div>
</section>
<script>
const yearSpan = document.getElementById("year");
if (yearSpan) {
  yearSpan.textContent = new Date().getFullYear().toString();
}
</script>
