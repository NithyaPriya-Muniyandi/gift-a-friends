---
import step1 from '../assets/one.webp';
import step2 from '../assets/two.webp';
import step3 from '../assets/three.webp';
---
<section class="py-10 md:py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 text-center">
    <h2 class="text-xl md:text-3xl font-extrabold text-[#2F2E67] uppercase mb-12">
      How It Works
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-center">
      <!-- Step 1 -->
      <div class="flex flex-col items-center px-6">
        <img src={step1.src} alt="Step 1" class="w-16 h-16 mb-4" />
        <p class="text-gray-700">
          Refer 5 friends who are interested in joining TAU for any academic program.
        </p>
      </div>

      <!-- Step 2 -->
      <div class="flex flex-col items-center px-6">
        <img src={step2.src} alt="Step 2" class="w-16 h-16 mb-4" />
        <p class="text-gray-700">
          Once all 5 referrals successfully complete their application process, you’ll be rewarded with one CPD course of your choice—absolutely FREE!
        </p>
      </div>

      <!-- Step 3 -->
      <div class="flex flex-col items-center px-6">
        <img src={step3.src} alt="Step 3" class="w-16 h-16 mb-4" />
        <p class="text-gray-700">
          It’s that simple—no fees, no complications, just smart sharing.
        </p>
      </div>
    </div>
  </div>
</section>
