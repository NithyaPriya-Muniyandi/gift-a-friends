---
import Logo from './../assets/gy-logo.webp';
import Deal from './../assets/deal.webp';
import Bac from './../assets/bac.webp';
import { Image } from "astro:assets";
import arrow from './../assets/arrow-sub.webp';

const currentUrl = Astro.url.href;
const parsedUrl = new URL(currentUrl);
const params = parsedUrl.searchParams;
const campaignNameCustom = params.get('campaign_name_custom') || '';
const netcore = params.get('netcore_activity_source') || '';
const leadSource = params.get('lead_source') || '';
const utmTerm = params.get('utm_term') || '';


// Qualifications list
const qualifications = [
  "Bachelor Degree in Health Science",
  "MBBS",
  "Bachelor in Bio Science",
  "Bachelor in Pharmacy",
  "Bachelor Degree in Public Health",
  "Bachelor Degree in Paramedical Science",
  "Bachelor Degree in Social Work",
  "Bachelor in Others"
];

---

<section
  class="relative overflow-hidden hero-banner py-5 px-2 md:pt-[50px] 
         md:bg-[url('../assets/banner-gy.webp')] bg-[#114869] bg-[url('../assets/ph-mobile.webp')] bg-no-repeat bg-[position:top_center]">
  <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-12 gap-6 items-start">
    <!-- Left Column -->
    <div class="md:col-span-5">
      <img src={Logo.src} alt="Logo" class="w-[100px] sm:w-[160px]" />
      <h1 class="text-white text-xl mt-5 md:text-4xl font-semibold w-[70%] md:w-[80%] md:my-10">Enlist for a Master’s in Public Health – Shape a Healthier Nation!</h1>
      <img src={Bac.src} alt="Graphic" class="block md:hidden pt-4 w-[100px] mx:0 md:mx-auto" />
      <!-- Deal Row -->
      <div class="grid grid-cols-12 items-start md:items-center mt-6">
        <div class="col-span-12">
          <div class="inline-block">
            <img src={Deal.src} alt="Deal" class="hidden md:block w-[100px]" />
            <div class="bg-white text-[#114869] block md:hidden font-semibold text-lg text-center px-4 py-2 rounded-t-xl">
                Exclusive Deal
              </div>
          </div>
        </div>
        <div class="col-span-12 text-left md:text-left">
          <div class="bg-[#FFE44D] text-[#114869] font-semibold text-md md:text-xl px-5 py-3 rounded-b-xl rounded-tr-xl">
            Receive a $1000 Discount on Tuition Fees!
          </div>
          <div class="text-white text-left text-lg md:text-xl pt-2">Hurry, Limited Seats Available</div>
        </div>
      </div>
    </div>

    <!-- Middle Bac Image -->
    <div class="hidden md:block md:col-span-3 pt-[110px] -ml-[80px]">
      <img src={Bac.src} alt="Graphic Bac" />
    </div>

    <!-- Right Apply Form -->
    <div class="md:col-span-4">
